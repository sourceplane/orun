{
  "$id": "https://orun.io/schemas/component-yaml.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": true,
  "description": "Authored component.yaml shape per specs/orun-component-catalog/data-model.md §6.",
  "properties": {
    "apiVersion": {
      "type": "string"
    },
    "kind": {
      "type": "string"
    },
    "metadata": {
      "additionalProperties": true,
      "properties": {
        "annotations": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "description": {
          "type": "string"
        },
        "labels": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "name": {
          "type": "string"
        },
        "title": {
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "spec": {
      "additionalProperties": true,
      "properties": {
        "change": {
          "additionalProperties": false,
          "properties": {
            "watches": {
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          },
          "type": "object"
        },
        "consumesApis": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "dependsOn": {
          "items": {
            "additionalProperties": true,
            "properties": {
              "component": {
                "type": "string"
              },
              "include": {
                "type": "string"
              },
              "input": {
                "type": "boolean"
              },
              "optional": {
                "type": "boolean"
              },
              "relationship": {
                "type": "string"
              }
            },
            "required": [
              "component"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "docs": {
          "additionalProperties": false,
          "properties": {
            "adrs": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "overview": {
              "type": "string"
            },
            "runbooks": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "techdocs": {
              "type": "string"
            }
          },
          "type": "object"
        },
        "domain": {
          "type": "string"
        },
        "env": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "environments": {
          "additionalProperties": {
            "additionalProperties": false,
            "properties": {
              "profile": {
                "type": "string"
              }
            },
            "required": [
              "profile"
            ],
            "type": "object"
          },
          "type": "object"
        },
        "extensions": {
          "additionalProperties": {},
          "type": "object"
        },
        "integrations": {
          "additionalProperties": {},
          "type": "object"
        },
        "labels": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "lifecycle": {
          "type": "string"
        },
        "links": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "icon": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "url": {
                "type": "string"
              }
            },
            "required": [
              "title",
              "url"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "owner": {
          "type": "string"
        },
        "parameters": {
          "additionalProperties": {},
          "type": "object"
        },
        "path": {
          "type": "string"
        },
        "providesApis": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "subscribe": {
          "additionalProperties": false,
          "properties": {
            "environments": {
              "items": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "profile": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "name"
                    ],
                    "type": "object"
                  }
                ]
              },
              "type": "array"
            }
          },
          "type": "object"
        },
        "system": {
          "type": "string"
        },
        "type": {
          "type": "string"
        }
      },
      "required": [
        "type"
      ],
      "type": "object"
    }
  },
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "title": "ComponentYAML",
  "type": "object"
}
