{
  "$id": "https://orun.io/schemas/component-yaml.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "description": "Authored component.yaml shape per specs/orun-component-catalog/data-model.md §6.",
  "properties": {
    "apiVersion": {
      "type": "string"
    },
    "kind": {
      "type": "string"
    },
    "metadata": {
      "additionalProperties": false,
      "properties": {
        "annotations": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "description": {
          "type": "string"
        },
        "labels": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "name": {
          "type": "string"
        },
        "title": {
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "spec": {
      "additionalProperties": false,
      "properties": {
        "consumesApis": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "dependsOn": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "component": {
                "type": "string"
              },
              "optional": {
                "type": "boolean"
              },
              "relationship": {
                "type": "string"
              }
            },
            "required": [
              "component"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "environments": {
          "additionalProperties": {
            "additionalProperties": false,
            "properties": {
              "profile": {
                "type": "string"
              }
            },
            "required": [
              "profile"
            ],
            "type": "object"
          },
          "type": "object"
        },
        "lifecycle": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "providesApis": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "system": {
          "type": "string"
        },
        "type": {
          "type": "string"
        }
      },
      "required": [
        "type"
      ],
      "type": "object"
    }
  },
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "title": "ComponentYAML",
  "type": "object"
}
